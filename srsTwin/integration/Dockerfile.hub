#
# srsTwin IQ hub: a small Python/ZeroMQ relay between the ocudu gNB and N srsUEs.
# Build context = integration/ (so it picks up hub/).
FROM python:3.12-slim
ENV PYTHONUNBUFFERED=1
RUN pip install --no-cache-dir pyzmq==26.2.0 numpy==2.1.3
WORKDIR /hub
COPY hub/ /hub/
ENTRYPOINT ["python", "iqhub.py"]
